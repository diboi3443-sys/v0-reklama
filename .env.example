# v0-reklama Environment Variables

# ============================================
# DATABASE (Supabase)
# ============================================
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# ============================================
# REDIS (Upstash)
# Get from: https://upstash.com
# ============================================
REDIS_URL=rediss://default:[PASSWORD]@[ENDPOINT].upstash.io:6379
UPSTASH_REDIS_REST_URL=https://[ENDPOINT].upstash.io
UPSTASH_REDIS_REST_TOKEN=your-rest-token-here

# ============================================
# AI MODELS
# ============================================
OPENROUTER_API_KEY=sk-or-v1-...
OPENAI_API_KEY=sk-...
REPLICATE_API_TOKEN=r8_...

# ============================================
# STORAGE (MinIO or Supabase Storage)
# ============================================
# Option 1: Supabase Storage (recommended for start)
STORAGE_PROVIDER=supabase
STORAGE_BUCKET=higgsfield-media

# Option 2: MinIO (for production)
# STORAGE_PROVIDER=minio
# MINIO_ENDPOINT=your-minio-server.com
# MINIO_PORT=9000
# MINIO_USE_SSL=true
# MINIO_ACCESS_KEY=your-access-key
# MINIO_SECRET_KEY=your-secret-key
# MINIO_BUCKET=higgsfield-media

# ============================================
# PAYMENT (YooKassa)
# Get from: https://yookassa.ru/my/merchant/integration/api-keys
# ============================================
YOOKASSA_SHOP_ID=your-shop-id-here
YOOKASSA_SECRET_KEY=your-secret-key-here

# ============================================
# APP CONFIG
# ============================================
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# MONITORING (Optional)
# ============================================
SENTRY_DSN=
LOGTAIL_SOURCE_TOKEN=

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_FREE_DAILY=10
RATE_LIMIT_STARTER_DAILY=100
RATE_LIMIT_PRO_DAILY=500
RATE_LIMIT_STUDIO_DAILY=2000
